<?xml version="1.0" encoding="UTF-8"?>
<!-- Urban Routes for Testing -->
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle Types -->
    <vType id="car" accel="2.6" decel="4.5" sigma="0.5" length="5" minGap="2.5" maxSpeed="50" guiShape="passenger"/>

    <!-- Routes -->
    <route id="route0" edges="E0 E1"/>
    <route id="route1" edges="E2 E3"/>
    <route id="route2" edges="E4 E5"/>
    <route id="route3" edges="E0 E4 E5"/>

    <!-- Vehicles -->
    <vehicle id="veh0" type="car" route="route0" depart="1.0" color="1,0,0"/>
    <vehicle id="veh1" type="car" route="route0" depart="2.0" color="0,1,0"/>
    <vehicle id="veh2" type="car" route="route1" depart="3.0" color="0,0,1"/>
