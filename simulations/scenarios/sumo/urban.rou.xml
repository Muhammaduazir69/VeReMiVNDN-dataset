    <vehicle id="veh5" type="car" route="route0" depart="10.0" color="0,1,1"/>
    <vehicle id="veh6" type="car" route="route0" depart="15.0" color="1,0,0"/>
    <vehicle id="veh7" type="car" route="route1" depart="20.0" color="0,1,0"/>
    <vehicle id="veh8" type="car" route="route2" depart="25.0" color="0,0,1"/>
    <vehicle id="veh9" type="car" route="route3" depart="30.0" color="1,1,0"/>

</routes>
