<?xml version="1.0" encoding="UTF-8"?>
<!--
    VeReMiVNDN - Advanced Vehicle Type Definitions

    This file defines multiple realistic vehicle types for SUMO simulation:
    - Passenger cars (regular, sports, emergency)
    - Buses (city, intercity)
    - Trucks (delivery, heavy)
    - Bicycles
    - Pedestrians
    - Motorcycles

    Each type has realistic physical and behavioral parameters
-->
<additional xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/additional_file.xsd">

    <!-- =============================================== -->
    <!-- PASSENGER CARS -->
    <!-- =============================================== -->

    <!-- Regular Passenger Car (Sedan) -->
    <vType id="passenger_sedan"
           vClass="passenger"
           accel="2.6"
           decel="4.5"
           sigma="0.5"
           length="4.5"
           minGap="2.5"
           maxSpeed="55.56"
           speedFactor="1.0"
           speedDev="0.1"
           color="0.8,0.8,0.8"
           guiShape="passenger"
           emissionClass="HBEFA3/PC_G_EU4"
           width="1.8"
           height="1.5">
        <param key="has.rerouting.device" value="true"/>
        <param key="has.bluelight.device" value="false"/>
    </vType>

    <!-- Sports Car (High Performance) -->
    <vType id="passenger_sport"
           vClass="passenger"
           accel="3.5"
           decel="6.0"
           sigma="0.3"
           length="4.2"
           minGap="2.0"
           maxSpeed="69.44"
           speedFactor="1.2"
           speedDev="0.15"
           color="1.0,0.0,0.0"
           guiShape="passenger/sedan"
           emissionClass="HBEFA3/PC_G_EU4"
           width="1.9"
           height="1.3">
        <param key="has.rerouting.device" value="true"/>
        <param key="junctionModel.ignoreKeepClearTime" value="5"/>
    </vType>

    <!-- SUV / Off-road Vehicle -->
    <vType id="passenger_suv"
           vClass="passenger"
           accel="2.2"
           decel="4.0"
           sigma="0.5"
           length="5.0"
           minGap="2.8"
           maxSpeed="50.00"
           speedFactor="0.95"
           speedDev="0.12"
           color="0.2,0.2,0.5"
           guiShape="passenger/van"
           emissionClass="HBEFA3/PC_G_EU4"
           width="2.0"
           height="1.8">
        <param key="has.rerouting.device" value="true"/>
    </vType>

    <!-- Taxi -->
    <vType id="passenger_taxi"
           vClass="taxi"
           accel="2.9"
           decel="5.0"
           sigma="0.4"
           length="4.6"
           minGap="2.3"
           maxSpeed="58.33"
           speedFactor="1.05"
           speedDev="0.1"
           color="1.0,1.0,0.0"
           guiShape="taxi"
           emissionClass="HBEFA3/PC_G_EU4"
           width="1.8"
           height="1.5">
        <param key="has.rerouting.device" value="true"/>
        <param key="has.taxi.device" value="true"/>
    </vType>

    <!-- Emergency Vehicle (Ambulance/Police) -->
    <vType id="emergency"
           vClass="emergency"
           accel="3.8"
           decel="7.0"
           sigma="0.2"
           length="5.5"
